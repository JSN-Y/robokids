{
  "version": 2,
  "installCommand": "corepack enable pnpm@10 && pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "artifacts/api-server/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["lib/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/artifacts/api-server/src/app.ts"
    }
  ]
}
